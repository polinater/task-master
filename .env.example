# ── Linear ──────────────────────────────────────────────────────────────────
# Personal API key: Linear → Settings → Security & access → Personal API keys
LINEAR_API_KEY=
# Team id (a UUID). Linear → Settings → Teams → <team> → the id in the URL,
# or ask via the API. NOT the team key like "CORE".
LINEAR_TEAM_ID=

# ── Attio ───────────────────────────────────────────────────────────────────
# Attio → Settings → Developers → create an access token (needs task read access)
ATTIO_API_KEY=
# Workspace-member email or id whose tasks should be synced
ATTIO_ASSIGNEE=
# Optional: your workspace slug, only used to build a "view in Attio" link
# (e.g. https://app.attio.com/<slug>/tasks)
ATTIO_WORKSPACE_SLUG=

# ── Google ──────────────────────────────────────────────────────────────────
# From a Google Cloud OAuth 2.0 Client (Desktop app or Web application type)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Obtained by running: npm run auth  (see README)
GOOGLE_REFRESH_TOKEN=
# Optional: target task list. "@default" is the account's primary list.
GOOGLE_TASKLIST_ID=@default

# ── Upstash Redis (the mapping database) ─────────────────────────────────────
# Provision from the Vercel Marketplace (Storage → Upstash → Redis). The
# integration injects these automatically in Vercel; set them here for local dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Behaviour ───────────────────────────────────────────────────────────────
# Days back to keep watching closed items so completion propagates. Default 14.
SYNC_LOOKBACK_DAYS=14
# Shared secret guarding the /api/sync endpoint. Vercel Cron sends this
# automatically as `Authorization: Bearer <CRON_SECRET>`. Recommended.
CRON_SECRET=
